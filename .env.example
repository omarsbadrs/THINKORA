# ============================================================
# THINKORA — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# The app runs in DEMO_MODE when credentials are missing.
# ============================================================

# --- Supabase (App Backend) ---
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# --- OpenRouter (Model Gateway) ---
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Thinkora

# Default models (slugs from OpenRouter catalog)
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4
OPENROUTER_DEFAULT_FAST_MODEL=anthropic/claude-haiku-4
OPENROUTER_DEFAULT_REASONING_MODEL=anthropic/claude-sonnet-4
OPENROUTER_DEFAULT_VISION_MODEL=anthropic/claude-sonnet-4
OPENROUTER_DEFAULT_EMBEDDING_MODEL=openai/text-embedding-3-small

# Routing & policy
OPENROUTER_ENABLE_AUTO_ROUTER=true
OPENROUTER_ENABLE_MODEL_FALLBACKS=true
OPENROUTER_DEFAULT_ALLOWED_MODELS=
OPENROUTER_DEFAULT_IGNORED_PROVIDERS=
OPENROUTER_REQUIRE_ZDR=false
OPENROUTER_DATA_COLLECTION_POLICY=deny
OPENROUTER_REQUIRE_PARAMETERS_MATCH=false
OPENROUTER_MAX_REQUEST_COST_USD=1.00

# Cache & sync
OPENROUTER_MODEL_CACHE_TTL_SECONDS=3600
OPENROUTER_MODELS_SYNC_CRON=0 */6 * * *
OPENROUTER_ENABLE_PROMPT_CACHING=true
OPENROUTER_LOG_RAW_ROUTING_METADATA=false

# Budget
OPENROUTER_BUDGET_DAILY_USD=10.00
OPENROUTER_BUDGET_MONTHLY_USD=200.00

# --- Notion MCP ---
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret
NOTION_REDIRECT_URI=http://localhost:3000/api/connectors/notion/callback
NOTION_MCP_BASE_URL=

# --- Supabase MCP ---
SUPABASE_MCP_URL=
SUPABASE_MCP_ACCESS_TOKEN=

# --- Storage ---
STORAGE_BUCKET_UPLOADS=uploads

# --- Security ---
APP_ENCRYPTION_KEY=generate-a-32-byte-hex-key
SESSION_SECRET=generate-a-random-session-secret

# --- Services ---
API_BASE_URL=http://localhost:4000
WORKER_BASE_URL=http://localhost:4100
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- App Config ---
DEMO_MODE=false
MAX_UPLOAD_MB=50
OCR_ENABLED=false
LOG_LEVEL=info

# --- Monitoring (optional) ---
SENTRY_DSN=

# --- Queue (BullMQ / Redis) ---
REDIS_URL=redis://localhost:6379
